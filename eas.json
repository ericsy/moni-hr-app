{
  "cli": {
    "version": ">= 19.0.8",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_ENV": "dev"
      }
    },
    "dev": {
      "distribution": "internal",
      "env": {
        "APP_ENV": "dev"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "test": {
      "distribution": "internal",
      "env": {
        "APP_ENV": "test"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "APP_ENV": "test"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "APP_ENV": "pro"
      }
    },
    "testflight": {
      "distribution": "store",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "test"
      }
    }
  },
  "submit": {
    "production": {},
    "testflight": {}
  }
}
